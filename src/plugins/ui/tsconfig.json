{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": "dist/server",
    "rootDir": ".",
    "noEmit": false
  },
  "include": ["admin/src/**/*", "server/**/*", "strapi-server.js"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
