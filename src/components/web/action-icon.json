      "required": true,
      "default": 40
    },
    "width": {
      "type": "integer",
      "required": true,
      "default": 40
    },
    "margin": {
      "type": "component",
      "component": "web.spacing",
      "repeatable": false
    }
  },
  "config": {}
}
