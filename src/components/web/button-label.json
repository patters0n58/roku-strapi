          "==": [
            {
              "var": "enableCustomLabel"
            },
            false
          ]
        }
      }
    },
    "enableCustomLabel": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "customLabel": {
      "type": "string",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "enableCustomLabel"
            },
            true
          ]
        }
      }
    },
    "color": {
      "type": "component",
      "component": "web.color",
      "repeatable": false
    },
    "hoverColor": {
      "type": "component",
      "component": "web.color",
      "repeatable": false,
      "required": false
    },
    "selectedColor": {
      "type": "component",
      "component": "web.color",
      "repeatable": false
    },
    "fontFamily": {
      "type": "enumeration",
      "required": true,
      "default": "serif",
      "enum": [
        "serif",
        "sansSerif",
        "monospace",
        "cursive",
        "fantasy",
        "inter",
        "montserrat"
      ]
    },
    "fontSize": {
      "type": "integer",
      "required": true
    },
    "fontHeight": {
      "type": "integer",
      "required": true
    },
    "fontSpacing": {
      "type": "integer",
      "required": true,
      "default": 0
