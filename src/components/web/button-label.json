      "enum": [
        "none",
        "underline",
        "strikethrough"
      ]
    },
    "margin": {
      "type": "component",
      "component": "web.spacing",
      "repeatable": false
    },
    "fontWeight": {
      "type": "enumeration",
      "enum": [
        "normal",
        "bold",
        "bolder",
        "lighter"
      ]
    },
    "padding": {
      "type": "component",
      "component": "web.spacing",
      "repeatable": false,
      "required": false
