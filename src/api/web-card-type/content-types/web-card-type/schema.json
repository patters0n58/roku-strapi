{
  "kind": "collectionType",
  "collectionName": "web_card_types",
  "info": {
    "singularName": "web-card-type",
    "pluralName": "web-card-types",
    "displayName": "Web Card Type"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "layout": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::web-layout.web-layout"
    },
    "tenant": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::tenant.tenant"
    },
    "card_type": {
      "type": "enumeration",
      "required": true,
      "default": "card_type_1",
      "enum": [
        "card_type_1",
        "card_type_2",
        "hero_card",
        "info_card"
      ]
    },
    "card_type_2": {
      "type": "component",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "card_type"
            },
            "card_type_2"
          ]
        }
      },
      "component": "web.card-type-2",
      "repeatable": false
    },
    "card_type_1": {
      "type": "component",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "card_type"
            },
            "card_type_1"
          ]
        }
      },
      "component": "web.card-type1",
      "repeatable": false
    },
    "hero_card": {
      "type": "component",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "card_type"
            },
            "hero_card"
          ]
        }
      },
      "component": "web.hero-card",
      "repeatable": false
    },
    "info_card": {
      "type": "component",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "card_type"
            },
            "info_card"
          ]
        }
      },
      "component": "web.info-card",
      "repeatable": false
    }
  }
}
