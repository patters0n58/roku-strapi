{
  "kind": "collectionType",
  "collectionName": "web_apps",
  "info": {
    "singularName": "web-app",
    "pluralName": "web-apps",
    "displayName": "Web App"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "version": {
      "type": "string"
    },
    "log_level": {
      "type": "enumeration",
      "enum": [
        "debug",
        "info",
        "warn",
        "error"
      ]
    },
    "tenant": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::tenant.tenant"
    },
    "layout": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::web-layout.web-layout"
    }
  }
}
