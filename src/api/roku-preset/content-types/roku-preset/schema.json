{
  "kind": "collectionType",
  "collectionName": "roku_presets",
  "info": {
    "singularName": "roku-preset",
    "pluralName": "roku-presets",
    "displayName": "Roku Preset"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "preset_name": {
      "type": "string",
      "required": true
    },
    "layout": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::roku-layout.roku-layout"
    },
    "tenant": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::tenant.tenant"
    },
    "preset_blocks": {
      "type": "dynamiczone",
      "components": [
        "roku.horizontal-list",
        "roku.grid"
      ],
      "required": true,
      "min": 1,
      "max": 1
    }
  }
}
